<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CadastrarMidiaActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.457"
        tools:layout_editor_absoluteX="0dp">

        <EditText
            android:id="@+id/etTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Título" />

        <EditText
            android:id="@+id/etAno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ano"
            android:inputType="number" />

        <Spinner
            android:id="@+id/spinnerTipoMidia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:id="@+id/layoutMusica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etArtista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Artista" />

            <EditText
                android:id="@+id/etAlbum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Álbum" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etDiretor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Diretor" />

            <EditText
                android:id="@+id/etDuracao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Duração em minutos"
                android:inputType="number" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPodcast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etAnfitriao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Anfitrião" />

            <EditText
                android:id="@+id/etEpisodio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número do episódio"
                android:inputType="number" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCadastrar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Cadastrar mídia" />

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnVoltarMidia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="Voltar" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>